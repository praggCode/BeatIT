# Frontend environment variables (Vite)
# Copy this to .env.local for local dev, or set in Vercel dashboard for production

# Your Render backend URL (no trailing slash)
# Local dev: http://localhost:3001
# Production: https://your-beatit-backend.onrender.com
VITE_API_URL=http://localhost:3001

# WebSocket URL — must match VITE_API_URL but with ws:// or wss:// scheme
# Local dev: ws://localhost:3001
# Production: wss://your-beatit-backend.onrender.com
VITE_WS_URL=ws://localhost:3001
